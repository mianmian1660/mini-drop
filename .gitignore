# ============================================================
# .gitignore — Git 忽略规则 小白版注释
# ============================================================
# 这个文件告诉 Git：哪些文件/目录不要提交到仓库
# 好处：仓库保持干净，别人 clone 后自己编译生成
#
# 语法：每行一个规则
#   *.后缀   = 忽略所有该后缀的文件
#   /目录名  = 忽略该目录
#   !xxx     = 例外（不忽略）
# ============================================================

# ----- 编译产物（别人会自己编译）-----
build/
cmake-build-*/
dist/
# npm 依赖（由 npm install 生成）
node_modules/

# ----- C++ 编译产物 -----
# 目标文件
*.o
# 静态库
*.a
# 动态库
*.so
# protobuf 生成的 C++ 源文件
*.pb.cc
# protobuf 生成的 C++ 头文件
*.pb.h
*.grpc.pb.cc
*.grpc.pb.h

# ----- Go 产物 -----
*.exe
*.test
vendor/
# apiserver 编译产物
apiserver/apiserver

# ----- Python 产物 -----
# Python 缓存目录
__pycache__/
# 编译后的 .pyc 文件
*.py[cod]
*.egg-info/
.eggs/
# 虚拟环境（每个人自己创建）
.venv/
venv/

# ----- IDE 配置（各人用的编辑器不同）-----
# VS Code 配置
.vscode/
# JetBrains IDE 配置
.idea/
# Vim 临时文件
*.swp
*.swo
*~

# ----- 操作系统临时文件 -----
# macOS
.DS_Store
# Windows
Thumbs.db

# ----- 敏感配置（不要把密码提交到 Git！）-----
.env
.env.local

# ----- 日志文件 -----
*.log

# ----- Proto 生成代码（由 protoc/cmake 自动生成，不提交）-----
drop/gen/
drop/tools/py_gen/__pycache__/

# ----- 已知的本地生成目录（显式忽略，确保跨平台兼容）-----
analysis/__pycache__/
web_frontend/node_modules/
